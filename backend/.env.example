# ═══════════════════════════════════════════════════════════════
# Auto Transcription — Backend Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Highest priority — overrides YAML config and field defaults
# Pydantic-settings prefix: AT_ | nested delimiter: __
# Priority: env vars > .env > YAML > defaults
# ═══════════════════════════════════════════════════════════════

# ── Environment ──────────────────────────────────────────────
# Options: dev | staging | prod | test
AT_ENV=dev

# ── Server ───────────────────────────────────────────────────
# AT_DEBUG=true
# AT_HOST=0.0.0.0
# Makefile runs uvicorn on 8100; set here too for standalone runs
AT_PORT=8100
# AT_CORS_ORIGINS=["http://localhost:3000"]

# ── Pipeline Mode ────────────────────────────────────────────
# azure_di:       Azure Document Intelligence only (fast, no local ML)
# marker_docling: Marker + Docling + Ollama (fully offline, slower)
# datalab:        Data Lab (Chandra) — superior handwriting + tables
AT_PIPELINE__MODE=azure_di

# ── Azure Document Intelligence ──────────────────────────────
# Required when AT_PIPELINE__MODE=azure_di (cloud API or disconnected container)
# Get from: Azure Portal → Azure AI Foundry → Document Intelligence
AT_AZURE_DI__ENDPOINT=https://your-resource.cognitiveservices.azure.com
AT_AZURE_DI__API_KEY=your-api-key-here
# AT_AZURE_DI__ANALYZE_TIMEOUT_SECONDS=900
# AT_AZURE_DI__PROGRESS_POLL_INTERVAL_SECONDS=2
# AT_AZURE_DI__SUBMIT_MAX_RETRIES=3
# AT_AZURE_DI__SUBMIT_RETRY_BASE_DELAY=5.0
# AT_AZURE_DI__CHUNK_PAGES=50

# ── Data Lab (Chandra) OCR ────────────────────────────────────
# Required when AT_PIPELINE__MODE=datalab
# Get API key from: https://www.datalab.to/app/keys
# AT_DATALAB__API_KEY=your-datalab-api-key-here
# AT_DATALAB__BASE_URL=https://www.datalab.to
# AT_DATALAB__TIMEOUT=300
# AT_DATALAB__MODE=accurate
# AT_DATALAB__EXTRAS=new_block_types,table_row_bboxes,chart_understanding
# AT_DATALAB__CHUNK_PAGES=50
# AT_DATALAB__MAX_CONCURRENT_CHUNKS=8  # Parallel chunk submission (API allows 400)
# AT_DATALAB__POLL_INTERVAL=1.0        # Status poll frequency (seconds)
# AT_DATALAB__SUBMIT_MAX_RETRIES=3
# AT_DATALAB__SUBMIT_RETRY_BASE_DELAY=5.0
# AT_DATALAB__DISABLE_IMAGE_EXTRACTION=true   # Skip image model (saves server time)
# AT_DATALAB__DISABLE_IMAGE_CAPTIONS=true     # Skip caption model (saves server time)
#
# Quality enhancements (all default-on for best accuracy)
# AT_DATALAB__USE_LLM=true
# AT_DATALAB__FORCE_OCR=false
# AT_DATALAB__STRIP_EXISTING_OCR=false
#
# Structured extraction via Extract API (fills key_value_pairs)
# AT_DATALAB__ENABLE_EXTRACTION=true
# AT_DATALAB__SAVE_CHECKPOINT=true
# Families: bpr_core, manufacturing_checklists, instrument_data_reports,
#           analysis_reports, sieving_reports (loaded from extraction_schemas.yaml)
# AT_DATALAB__EXTRACTION_SCHEMA_FAMILY=bpr_core
# AT_DATALAB__EXTRACTION_SCHEMA={}  # Override: raw JSON schema (bypasses YAML lookup)
#
# Bounding box enrichment (fetches JSON output for per-block polygons)
# AT_DATALAB__FETCH_BLOCK_BBOXES=true

# ── LLM Provider (general / marker_docling pipeline) ────────
# Options: ollama (local, on-prem) | azure_openai (cloud)
AT_LLM__PROVIDER=ollama
AT_LLM__BASE_URL=http://localhost:11434
AT_LLM__MODEL=gemma2:9b
# Azure OpenAI (uncomment if AT_LLM__PROVIDER=azure_openai)
# AT_LLM__API_KEY=your-openai-api-key-here
# AT_LLM__AZURE_ENDPOINT=https://your-openai-resource.openai.azure.com
# AT_LLM__AZURE_DEPLOYMENT=gpt-4o
# AT_LLM__AZURE_MAX_RPM=800
# AT_LLM__AZURE_MAX_CONCURRENT=25

# ── Compliance LLM ───────────────────────────────────────────
# Compliance agents use a SEPARATE LLM config — defaults to azure_openai
# even when the general LLM provider above is ollama.
# These credentials power the orchestrator, evaluator, and cross-page agents.
AT_COMPLIANCE__LLM_PROVIDER=azure_openai
AT_COMPLIANCE__API_KEY=your-compliance-openai-api-key-here
AT_COMPLIANCE__AZURE_ENDPOINT=https://your-openai-resource.openai.azure.com

# Evaluator model (per-page rule evaluation — needs structured output)
AT_COMPLIANCE__EVALUATOR_MODEL=gpt-4.1-mini
AT_COMPLIANCE__EVALUATOR_DEPLOYMENT=gpt-4.1-mini

# Orchestrator model (document routing + executive summary)
AT_COMPLIANCE__ORCHESTRATOR_MODEL=gpt-4.1-mini
AT_COMPLIANCE__ORCHESTRATOR_DEPLOYMENT=gpt-4.1-mini

# Cross-page reconciliation model (falls back to evaluator if empty)
# AT_COMPLIANCE__CROSS_PAGE_MODEL=
# AT_COMPLIANCE__CROSS_PAGE_DEPLOYMENT=

# Per-component overrides (evaluator_llm / orchestrator_llm)
# AT_COMPLIANCE__EVALUATOR_LLM__PROVIDER=
# AT_COMPLIANCE__EVALUATOR_LLM__MODEL=
# AT_COMPLIANCE__EVALUATOR_LLM__AZURE_ENDPOINT=
# AT_COMPLIANCE__EVALUATOR_LLM__AZURE_DEPLOYMENT=
# AT_COMPLIANCE__EVALUATOR_LLM__API_KEY=

# Compliance tuning
# AT_COMPLIANCE__RULE_BATCH_SIZE=15
# AT_COMPLIANCE__MAX_CONCURRENT_BATCHES=25
# AT_COMPLIANCE__BATCH_BY_CATEGORY=true
# AT_COMPLIANCE__LLM_TIMEOUT=120
# AT_COMPLIANCE__APPLICABILITY_MODE=static
# AT_COMPLIANCE__ENABLE_CROSS_PAGE=true
# AT_COMPLIANCE__AUTO_DISCOVER_CHECKS=true
# AT_COMPLIANCE__MAX_SECTION_CHARS=15000

# ── HITL (Human-in-the-Loop) ─────────────────────────────────
# AT_HITL__AUTO_APPROVE_THRESHOLD=0.8
# AT_HITL__REVIEW_THRESHOLD=0.6
# AT_HITL__BATCH_REVIEW_ENABLED=true

# ── Database ─────────────────────────────────────────────────
# Default matches the docker-compose.yml PostgreSQL service
AT_DATABASE__URL=postgresql+asyncpg://postgres:postgres@localhost:5432/autotranscription
AT_DATABASE__SYNC_URL=postgresql://postgres:postgres@localhost:5432/autotranscription

# ── Marker (used when AT_PIPELINE__MODE=marker_docling) ──────
AT_MARKER__OLLAMA_BASE_URL=http://localhost:11434
AT_MARKER__OLLAMA_MODEL=gemma2:9b

# ── VLM (Vision Language Model — visual compliance checks) ──
# VLM enables visual inspection of scanned pages for compliance rules
# that cannot be assessed from OCR text alone (strikethroughs, ink color,
# correction fluid, signatures, stamps, watermarks, etc.)
#
# Providers: gemini (Google API) | vllm (container-hosted, e.g. Qwen3-VL)
AT_VLM__ENABLED=false
AT_VLM__PROVIDER=gemini

# Gemini settings (when AT_VLM__PROVIDER=gemini)
# Models: gemini-2.5-pro (best accuracy, slower) | gemini-2.5-flash (balanced)
#       | gemini-2.5-flash-lite (fastest, cheapest)
AT_VLM__GEMINI_API_KEY=your-gemini-api-key-here
AT_VLM__GEMINI_MODEL=gemini-2.5-flash
# AT_VLM__GEMINI_PROJECT=your-gcp-project-id

# vLLM / OpenAI-compatible settings (when AT_VLM__PROVIDER=vllm)
# Use for self-hosted models like Qwen3-VL, InternVL3, Gemma 3
# AT_VLM__VLLM_BASE_URL=http://localhost:8200/v1
# AT_VLM__VLLM_MODEL=Qwen/Qwen3-VL-8B-Instruct
# AT_VLM__VLLM_API_KEY=

# Image processing
# AT_VLM__MAX_IMAGE_WIDTH=2048
# AT_VLM__MAX_IMAGE_HEIGHT=2048
# AT_VLM__IMAGE_FORMAT=png
# AT_VLM__RENDER_SCALE=2.0
# AT_VLM__STORE_PAGE_IMAGES=true

# Rate limiting
# AT_VLM__MAX_RPM=60
# AT_VLM__MAX_CONCURRENT=5

# Compliance VLM tuning
# AT_COMPLIANCE__VLM_EVALUATION_ENABLED=true
# AT_COMPLIANCE__VLM_BATCH_SIZE=5
# AT_COMPLIANCE__VLM_TIMEOUT=180
# AT_COMPLIANCE__VLM_FALLBACK_TO_TEXT=true

# ── OCR Correction Learning ──────────────────────────────────
# Tier 1: Runtime post-correction from learned OCR error patterns
# AT_FEEDBACK__AUTO_CORRECT_ENABLED=false
# AT_FEEDBACK__MIN_CORRECTION_OCCURRENCES=3
# AT_FEEDBACK__MIN_CORRECTION_SOURCE_DOCS=2
# AT_FEEDBACK__MIN_CORRECTION_CONFIDENCE=0.8
# AT_FEEDBACK__REBUILD_ON_REVIEW_SAVE=true
# AT_FEEDBACK__CORRECTION_STORE_PATH=data/corrections/global_corrections.json

# ── Storage ──────────────────────────────────────────────────
# Options: filesystem | azure_blob
AT_STORAGE__BACKEND=filesystem
AT_STORAGE__BASE_PATH=./data/documents

# Azure Blob Storage (staging/production):
# AT_STORAGE__BACKEND=azure_blob
# AT_STORAGE__AZURE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AT_STORAGE__AZURE_CONTAINER=documents
