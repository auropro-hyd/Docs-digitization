                <mxCell id="ports-group" value="&lt;b&gt;PORTS &amp; ADAPTERS&lt;/b&gt;  (Hexagonal Architecture)" style="swimlane;startSize=25;fillColor=#F3E5F5;strokeColor=#CE93D8;rounded=1;arcSize=8;fontSize=11;fontStyle=1;fontColor=#6A1B9A;" parent="1" vertex="1">
