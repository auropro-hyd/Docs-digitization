                </mxCell>
                <mxCell id="port-ocr" value="&lt;b&gt;OCREngine&lt;/b&gt; (port)&#10;→ PrimaryOCRAdapter&#10;→ AlternateOCRAdapter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#AB47BC;fontSize=8;fontColor=#6A1B9A;" parent="ports-group" vertex="1">
                    <mxGeometry x="30" y="35" width="170" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="port-llm" value="&lt;b&gt;LLMProvider&lt;/b&gt; (port)&#10;→ CloudLLMAdapter&#10;→ LocalLLMAdapter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#AB47BC;fontSize=8;fontColor=#6A1B9A;" parent="ports-group" vertex="1">
                    <mxGeometry x="230" y="35" width="180" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="port-storage" value="&lt;b&gt;DocumentStore&lt;/b&gt; (port)&#10;→ FileSystemAdapter&#10;→ AzureBlobAdapter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#AB47BC;fontSize=8;fontColor=#6A1B9A;" parent="ports-group" vertex="1">
                    <mxGeometry x="440" y="35" width="170" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="port-notify" value="&lt;b&gt;NotificationPort&lt;/b&gt; (port)&#10;→ WebSocketNotifyAdapter&#10;→ PgNotifyAdapter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#AB47BC;fontSize=8;fontColor=#6A1B9A;" parent="ports-group" vertex="1">
                    <mxGeometry x="640" y="35" width="180" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="port-quality" value="&lt;b&gt;QualityScorer&lt;/b&gt; (port)&#10;→ QualityScoringAdapter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#AB47BC;fontSize=8;fontColor=#6A1B9A;" parent="ports-group" vertex="1">
                    <mxGeometry x="850" y="35" width="170" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="ext-group" value="&lt;b&gt;EXTERNAL SERVICES &amp; STORAGE&lt;/b&gt;" style="swimlane;startSize=25;fillColor=#EDE7F6;strokeColor=#9575CD;rounded=1;arcSize=8;fontSize=12;fontStyle=1;fontColor=#4527A0;" parent="1" vertex="1">
                    <mxGeometry x="40" y="970" width="1520" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="ext-azdi" value="&lt;b&gt;Azure Document&#10;Intelligence&lt;/b&gt;&#10;(Layout model)&#10;ocrHighRes, tables,&#10;keyValue, signatures" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#64B5F6;fontSize=9;fontColor=#1565C0;" parent="ext-group" vertex="1">
                    <mxGeometry x="20" y="30" width="195" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="ext-azoai" value="&lt;b&gt;Azure OpenAI&lt;/b&gt;&#10;GPT-4.1-mini (evaluator)&#10;GPT-4.1-mini (orchestrator)&#10;gpt-4o (fallback)&#10;RPM limiting + retry" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF8A65;fontSize=9;fontColor=#BF360C;" parent="ext-group" vertex="1">
                    <mxGeometry x="230" y="30" width="220" height="85" as="geometry"/>
