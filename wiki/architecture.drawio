    <diagram id="doc-flow" name="Document Processing Flow">
        <mxGraphModel dx="1080" dy="548" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="t2" value="&lt;b&gt;Document Processing — Data Flow&lt;/b&gt;" style="text;html=1;fontSize=18;fontColor=#1A237E;align=center;" parent="1" vertex="1">
                    <mxGeometry x="400" y="20" width="800" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="user" value="&lt;b&gt;User&lt;/b&gt;" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fillColor=#C5CAE9;strokeColor=#5C6BC0;fontColor=#1A237E;" parent="1" vertex="1">
                    <mxGeometry x="60" y="100" width="40" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="s1" value="&lt;b&gt;1. Upload PDF&lt;/b&gt;&#10;POST /api/documents/upload&#10;&#10;→ Stores PDF to&#10;  data/documents/{doc_id}/&#10;→ Returns doc_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#64B5F6;fontSize=10;align=left;spacingLeft=10;fontColor=#1565C0;" parent="1" vertex="1">
                    <mxGeometry x="160" y="80" width="220" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="s2" value="&lt;b&gt;2. Trigger Processing&lt;/b&gt;&#10;POST /api/documents/{id}/process&#10;&#10;→ Creates processing.lock&#10;→ Launches BackgroundTask&#10;→ Opens WS /ws/{doc_id}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#64B5F6;fontSize=10;align=left;spacingLeft=10;fontColor=#1565C0;" parent="1" vertex="1">
                    <mxGeometry x="420" y="80" width="230" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="s3" value="&lt;b&gt;3. LangGraph Pipeline&lt;/b&gt;&#10;document_graph.py&#10;(MemorySaver checkpointer)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#FFA726;fontSize=11;fontStyle=1;fontColor=#E65100;" parent="1" vertex="1">
                    <mxGeometry x="310" y="230" width="260" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="n1" value="&lt;b&gt;ingest_document&lt;/b&gt;&#10;Read PDF bytes&#10;Get filename, metadata" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#FFA726;fontSize=9;fontColor=#E65100;" parent="1" vertex="1">
                    <mxGeometry x="60" y="320" width="170" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="n2" value="&lt;b&gt;route_after_ingest&lt;/b&gt;&#10;Check pipeline.mode&#10;(primary | alternate_offline)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#FFD54F;fontSize=9;fontColor=#F57F17;" parent="1" vertex="1">
                    <mxGeometry x="280" y="310" width="190" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="n3a" value="&lt;b&gt;run_primary_ocr&lt;/b&gt;&#10;Layout model&#10;high-res OCR, tables, signatures&#10;key-value pairs, formulas&#10;&#10;Real-time % via LRO polling&#10;WS: ocr_progress" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#64B5F6;fontSize=9;align=left;spacingLeft=8;fontColor=#1565C0;" parent="1" vertex="1">
                    <mxGeometry x="540" y="290" width="210" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="n3b" value="&lt;b&gt;run_alternate_ocr&lt;/b&gt;&#10;PDF→MD conversion&#10;(offline mode)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#AB47BC;fontSize=9;align=left;spacingLeft=8;fontColor=#6A1B9A;" parent="1" vertex="1">
                    <mxGeometry x="540" y="410" width="210" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="n3c" value="&lt;b&gt;run_quality_scoring&lt;/b&gt;&#10;QualityScoringAdapter&#10;Page-level quality scoring" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#AB47BC;fontSize=9;align=left;spacingLeft=8;fontColor=#6A1B9A;" parent="1" vertex="1">
                    <mxGeometry x="540" y="480" width="210" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="n4a" value="&lt;b&gt;merge_primary_results&lt;/b&gt;&#10;- Build HTML tables (rowspan/colspan)&#10;- Repeat headers for cross-page tables&#10;- Extract signatures, key-value pairs&#10;- Per-page markdown with structure&#10;- Compute per-page confidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF8A65;fontSize=9;align=left;spacingLeft=8;fontColor=#BF360C;" parent="1" vertex="1">
                    <mxGeometry x="810" y="290" width="250" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="n4b" value="&lt;b&gt;merge_alternate_results&lt;/b&gt;&#10;- Combine OCR + quality output&#10;- Build per-page markdown&#10;- Compute per-page confidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#AB47BC;fontSize=9;align=left;spacingLeft=8;fontColor=#6A1B9A;" parent="1" vertex="1">
                    <mxGeometry x="810" y="430" width="250" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="n5" value="&lt;b&gt;route_by_confidence&lt;/b&gt;&#10;min(page_scores) vs thresholds&#10;review_threshold=0.6&#10;auto_approve_threshold=0.8" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#FFD54F;fontSize=9;fontColor=#F57F17;" parent="1" vertex="1">
                    <mxGeometry x="1110" y="310" width="190" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="n6a" value="&lt;b&gt;auto_approve&lt;/b&gt;&#10;All pages ≥ 80% confidence&#10;→ status = approved" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#66BB6A;fontSize=9;fontColor=#2E7D32;" parent="1" vertex="1">
                    <mxGeometry x="1350" y="290" width="200" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="n6b" value="&lt;b&gt;hitl_review&lt;/b&gt;&#10;Page confidence &lt; 60%&#10;→ interrupt() for human review&#10;→ Command(resume=...) to continue" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FFAB91;fontSize=9;fontColor=#D84315;" parent="1" vertex="1">
                    <mxGeometry x="1350" y="360" width="210" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="n7" value="&lt;b&gt;store_results&lt;/b&gt;&#10;→ result.json&#10;→ document.json" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;size=10;fillColor=#E8F5E9;strokeColor=#66BB6A;fontSize=10;fontColor=#2E7D32;" parent="1" vertex="1">
                    <mxGeometry x="1380" y="460" width="140" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="n-error" value="&lt;b&gt;handle_error&lt;/b&gt;&#10;WS: error notification&#10;status = error" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#EF5350;fontSize=9;fontColor=#C62828;" parent="1" vertex="1">
                    <mxGeometry x="1130" y="490" width="160" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="rjson" value="&lt;b&gt;result.json contains:&lt;/b&gt;&#10;• filename, total_pages&#10;• extractions[]: page_num, markdown, confidence&#10;• raw_markdown: {page → md}&#10;• hitl_decisions: {page → status}&#10;• component_decisions: {id → {status, data}}&#10;• key_value_pairs: [{key, value, confidence}]&#10;• signatures: [{page, type, bbox}]&#10;• tables: [{page, html, rows, cols}]&#10;• confidence_scores: {page → score}" style="shape=note;whiteSpace=wrap;html=1;size=18;fillColor=#ECEFF1;strokeColor=#90A4AE;fontSize=9;align=left;spacingLeft=8;fontColor=#37474F;" parent="1" vertex="1">
                    <mxGeometry x="60" y="540" width="310" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="wsmsg" value="&lt;b&gt;WebSocket Messages:&lt;/b&gt;&#10;• processing_started&#10;• processing_stage {stage, label}&#10;• ocr_progress {percent_completed}&#10;• processing_progress {stage, progress}&#10;• hitl_required {pages_count, pages}&#10;• processing_complete {total_pages, has_hitl}&#10;• processing_error {error}&#10;• status {auto_approved | completed}" style="shape=note;whiteSpace=wrap;html=1;size=18;fillColor=#FBE9E7;strokeColor=#FF8A65;fontSize=9;align=left;spacingLeft=8;fontColor=#BF360C;" parent="1" vertex="1">
                    <mxGeometry x="420" y="540" width="280" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="review-title" value="&lt;b&gt;4. HITL Review (Frontend)&lt;/b&gt;" style="text;html=1;fontSize=13;fontColor=#C62828;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="780" y="540" width="250" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="rev1" value="GET /review/{id}/pages&#10;→ Side-by-side: PDF ↔ Markdown&#10;→ Scroll sync&#10;→ DocumentContextBar nav" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#EF9A9A;fontSize=9;fontColor=#C62828;" parent="1" vertex="1">
                    <mxGeometry x="780" y="570" width="200" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="rev2" value="POST approve / edit / flag&#10;(page-level or component-level)&#10;bulk component actions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#EF9A9A;fontSize=9;fontColor=#C62828;" parent="1" vertex="1">
                    <mxGeometry x="1010" y="570" width="200" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="rev3" value="GET export?format=md|html&#10;→ Download reviewed doc&#10;Completion banner → Compliance CTA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#EF9A9A;fontSize=9;fontColor=#C62828;" parent="1" vertex="1">
                    <mxGeometry x="1240" y="570" width="220" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="de1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#78909C;" parent="1" source="user" target="s1" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
