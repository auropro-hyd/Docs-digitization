    <diagram id="compliance-flow" name="Compliance Audit Pipeline">
        <mxGraphModel dx="1694" dy="821" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1400" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="t3" value="&lt;b&gt;Compliance Audit — Detailed Pipeline&lt;/b&gt;" style="text;html=1;fontSize=18;fontColor=#1A237E;align=center;" parent="1" vertex="1">
                    <mxGeometry x="400" y="10" width="800" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="trigger" value="&lt;b&gt;User triggers audit&lt;/b&gt;&#10;POST /compliance/{doc_id}/run&#10;{agents: [&quot;alcoa&quot;, &quot;gmp&quot;, ...]}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C5CAE9;strokeColor=#5C6BC0;fontSize=10;fontColor=#1A237E;" parent="1" vertex="1">
                    <mxGeometry x="60" y="60" width="250" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="loaddata" value="&lt;b&gt;Load from result.json&lt;/b&gt;&#10;extractions[], filename,&#10;total_pages, key_value_pairs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#90A4AE;fontSize=9;fontColor=#37474F;" parent="1" vertex="1">
                    <mxGeometry x="380" y="60" width="200" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="ph1-title" value="&lt;b&gt;Phase 1: Orchestrator&lt;/b&gt; (GPT-4.1-mini)" style="text;html=1;fontSize=13;fontColor=#880E4F;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="60" y="140" width="350" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="orch" value="&lt;b&gt;ComplianceOrchestrator.analyze()&lt;/b&gt;&#10;&#10;Input: filename, pages, first 3 page extractions, KV pairs&#10;Output: OrchestratorResult {&#10;  is_relevant, confidence, document_type,&#10;  applicable_categories, skipped_categories&#10;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#EC407A;fontSize=9;align=left;spacingLeft=10;fontColor=#880E4F;" parent="1" vertex="1">
                    <mxGeometry x="60" y="170" width="400" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="orch-ws" value="WS: phase=orchestrator&#10;→ status=running&#10;→ status=complete&#10;  {document_type, applicable, skipped}" style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#FBE9E7;strokeColor=#FF8A65;fontSize=8;align=left;fontColor=#BF360C;" parent="1" vertex="1">
                    <mxGeometry x="500" y="170" width="230" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="selected" value="&lt;b&gt;Agent Selection&lt;/b&gt;&#10;If user selected agents → use those&#10;Else → use orchestrator's applicable list&#10;Remaining → SkippedCategory(reason)&#10;If cross_page enabled → add &quot;reconciliation&quot;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#FFD54F;fontSize=9;fontColor=#F57F17;" parent="1" vertex="1">
                    <mxGeometry x="790" y="150" width="280" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="ph15-title" value="&lt;b&gt;Phase 1.5: Document Segmentation&lt;/b&gt; (LLM-based)" style="text;html=1;fontSize=13;fontColor=#880E4F;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="60" y="295" width="400" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="seg-box" value="&lt;b&gt;DocumentSegmenter.segment()&lt;/b&gt;&#10;&#10;Identifies distinct sub-documents in packet&#10;(page restarts, header changes, layout shifts)&#10;&#10;Output: DocumentSegmentation {sections: [&#10;  {section_id, name, type, start_page, end_page}&#10;]}&#10;&#10;Cached to segmentation.json&#10;build_page_to_section() → section_map" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#EC407A;fontSize=9;align=left;spacingLeft=10;fontColor=#880E4F;" parent="1" vertex="1">
                    <mxGeometry x="60" y="325" width="380" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="seg-ws" value="WS: phase=segmentation&#10;→ status=running&#10;→ status=complete&#10;  {sections_count}" style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#FBE9E7;strokeColor=#FF8A65;fontSize=8;align=left;fontColor=#BF360C;" parent="1" vertex="1">
                    <mxGeometry x="480" y="340" width="200" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="ph2-title" value="&lt;b&gt;Phase 2: Per-Page Agent Evaluation&lt;/b&gt; (Sequential agents, internal batch concurrency)" style="text;html=1;fontSize=13;fontColor=#BF360C;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="60" y="490" width="600" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="registry" value="&lt;b&gt;RuleRegistry&lt;/b&gt;&#10;&#10;Loads rules from *_rules.md&#10;agents_meta.json&#10;&#10;get_batches(agent, size=7, by_category=True)&#10;→ RuleBatch[] (batch_id, category, rules)&#10;&#10;CRUD: add/update/delete agents &amp; rules" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#9575CD;fontSize=9;align=left;spacingLeft=10;fontColor=#4527A0;" parent="1" vertex="1">
                    <mxGeometry x="60" y="530" width="280" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="agent-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FFB74D;dashed=1;dashPattern=5 5;" parent="1" vertex="1">
                    <mxGeometry x="380" y="520" width="820" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="agent-label" value="&lt;b&gt;For each agent (sequential):&lt;/b&gt; ALCOA+ → GMP → Checklist → SOP" style="text;html=1;fontSize=11;fontColor=#E65100;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="390" y="525" width="500" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="agent-init" value="&lt;b&gt;Agent.review_document()&lt;/b&gt;&#10;→ Load batches from registry&#10;→ WS: rules manifest (all rule IDs, text)&#10;→ Inject section_map &amp; global_kv_pairs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#FFA726;fontSize=9;fontColor=#E65100;" parent="1" vertex="1">
                    <mxGeometry x="400" y="555" width="230" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="fanout" value="&lt;b&gt;run_agent_evaluation()&lt;/b&gt;&#10;&#10;Fan-out: batch × page&#10;asyncio.Semaphore&#10;(max_concurrent_batches)&#10;&#10;Each task:&#10;  RuleBatchEvaluator.evaluate_batch()&#10;  → LLM call (GPT-4.1-mini)&#10;  → RuleBatchResult {evaluations, cross_references}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF8A65;fontSize=9;align=left;spacingLeft=10;fontColor=#BF360C;" parent="1" vertex="1">
                    <mxGeometry x="660" y="550" width="240" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="eval-detail" value="&lt;b&gt;RuleEvaluation:&lt;/b&gt;&#10;rule_id, status, &lt;b&gt;confidence&lt;/b&gt;,&#10;severity, evidence,&#10;description, recommendation&#10;&#10;&lt;b&gt;CrossReference:&lt;/b&gt;&#10;ref_type, identifier,&#10;context, page_num" style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#FFF3E0;strokeColor=#FF8A65;fontSize=8;align=left;fontColor=#BF360C;" parent="1" vertex="1">
                    <mxGeometry x="930" y="545" width="200" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="ws-rules" value="WS per batch:&#10;{phase: evaluation, agent,&#10; rule_updates: [{rule_id,&#10;  status, confidence}],&#10; batches_complete, percent}" style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#FBE9E7;strokeColor=#FF8A65;fontSize=8;align=left;fontColor=#BF360C;" parent="1" vertex="1">
                    <mxGeometry x="930" y="665" width="210" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="assemble" value="&lt;b&gt;assemble_agent_report()&lt;/b&gt;&#10;&#10;→ Deduplicate findings (merge pages)&#10;→ Compute CategoryScores&#10;→ &lt;b&gt;HITL: confidence &lt; 80% → needs_review&lt;/b&gt;&#10;→ AgentReport&#10;→ Store dependency_tags.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#81C784;fontSize=9;align=left;spacingLeft=10;fontColor=#2E7D32;" parent="1" vertex="1">
                    <mxGeometry x="400" y="640" width="230" height="95" as="geometry"/>
                </mxCell>
                <mxCell id="ph25-title" value="&lt;b&gt;Phase 2.5: Cross-Page Reconciliation&lt;/b&gt; (optional, enable_cross_page=True)" style="text;html=1;fontSize=13;fontColor=#C62828;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="60" y="760" width="550" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="recon-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#EF9A9A;dashed=1;dashPattern=5 5;" parent="1" vertex="1">
                    <mxGeometry x="60" y="790" width="1080" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="recon-resolver" value="&lt;b&gt;SectionResolver&lt;/b&gt;&#10;Maps rule [sections: ...]&#10;to DocumentSegmentation&#10;sections via LLM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#EF9A9A;fontSize=9;fontColor=#C62828;" parent="1" vertex="1">
                    <mxGeometry x="80" y="810" width="180" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="recon-eval" value="&lt;b&gt;CrossPageEvaluator&lt;/b&gt;&#10;Gathers content by section&#10;Evaluates multi-section rules&#10;group_rules_by_sections()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#EF9A9A;fontSize=9;fontColor=#C62828;" parent="1" vertex="1">
                    <mxGeometry x="290" y="810" width="200" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="recon-discovery" value="&lt;b&gt;AutoDiscovery&lt;/b&gt;&#10;Proposes extra cross-page checks&#10;→ auto_discovered_rules.json&#10;Supports rule promotion" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#EF9A9A;fontSize=9;fontColor=#C62828;" parent="1" vertex="1">
                    <mxGeometry x="520" y="810" width="210" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="recon-report" value="&lt;b&gt;ReconciliationAgent&lt;/b&gt;&#10;assemble_agent_report()&#10;→ AgentReport" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#81C784;fontSize=9;fontColor=#2E7D32;" parent="1" vertex="1">
                    <mxGeometry x="780" y="810" width="180" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="recon-ws" value="WS: phase=evaluation,&#10;agent=reconciliation" style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#FBE9E7;strokeColor=#FF8A65;fontSize=8;align=left;fontColor=#BF360C;" parent="1" vertex="1">
                    <mxGeometry x="980" y="815" width="145" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="re1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#78909C;" parent="1" source="recon-resolver" target="recon-eval" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="re2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#78909C;" parent="1" source="recon-eval" target="recon-discovery" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="re3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#78909C;" parent="1" source="recon-discovery" target="recon-report" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ph3-title" value="&lt;b&gt;Phase 3: Report Generation&lt;/b&gt;" style="text;html=1;fontSize=13;fontColor=#2E7D32;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="60" y="970" width="250" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="report-gen" value="&lt;b&gt;Report Assembly&lt;/b&gt;&#10;&#10;1. Collect all AgentReports (per-page + reconciliation)&#10;2. Deduplicate cross-agent findings&#10;3. Compute overall_score&#10;   = weighted avg of agent scores&#10;4. Generate ExecutiveSummary (GPT-4.1-mini)&#10;   {assessment, risks, strengths, actions}&#10;5. Build ComplianceReport" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#81C784;fontSize=9;align=left;spacingLeft=10;fontColor=#2E7D32;" parent="1" vertex="1">
                    <mxGeometry x="60" y="1000" width="320" height="145" as="geometry"/>
                </mxCell>
                <mxCell id="severity-weights" value="&lt;b&gt;SEVERITY_WEIGHTS:&lt;/b&gt;&#10;critical = 10&#10;major = 5&#10;minor = 2&#10;observation = 1" style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#ECEFF1;strokeColor=#90A4AE;fontSize=9;align=left;fontColor=#37474F;" parent="1" vertex="1">
                    <mxGeometry x="410" y="1000" width="150" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="comp-report-schema" value="&lt;b&gt;ComplianceReport:&lt;/b&gt;&#10;report_id, doc_id, filename, total_pages&#10;document_type, generated_at&#10;overall_score, score_methodology&#10;executive_summary:&#10;  {assessment, risks, strengths, actions}&#10;agent_reports[]: AgentReport&#10;  {agent, score, findings[], category_scores[]}&#10;skipped_agents[]: SkippedCategory&#10;findings[]: ComplianceFinding&#10;  {finding_id, rule_id, severity, &lt;b&gt;confidence&lt;/b&gt;,&#10;   &lt;b&gt;hitl_status&lt;/b&gt;, hitl_note, evidence, pages,&#10;   resolved, hitl_reviewed_at}&#10;audit_trail:&#10;  {duration, llm_calls, models, agents_executed,&#10;   agents_skipped, rule_batch_size}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#90A4AE;fontSize=9;align=left;spacingLeft=10;fontColor=#37474F;" parent="1" vertex="1">
                    <mxGeometry x="600" y="980" width="310" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="store-comp" value="→ compliance_result.json" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;size=10;fillColor=#E8F5E9;strokeColor=#66BB6A;fontSize=10;fontColor=#2E7D32;" parent="1" vertex="1">
                    <mxGeometry x="960" y="1030" width="170" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="ph4-title" value="&lt;b&gt;Phase 4: Compliance HITL Review (Frontend)&lt;/b&gt;" style="text;html=1;fontSize=13;fontColor=#D84315;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="60" y="1230" width="400" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="hitl-flow" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FFAB91;dashed=1;dashPattern=5 5;" parent="1" vertex="1">
                    <mxGeometry x="60" y="1260" width="1100" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="hitl1" value="&lt;b&gt;FindingsTable&lt;/b&gt;&#10;Shows all findings with:&#10;• Severity badge&#10;• Confidence % badge&#10;• HITL status badge&#10;• Filter by review status&#10;• Highlight finding from URL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#EF9A9A;fontSize=9;align=left;spacingLeft=8;fontColor=#C62828;" parent="1" vertex="1">
                    <mxGeometry x="80" y="1275" width="200" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="hitl2" value="&lt;b&gt;needs_review findings&lt;/b&gt;&#10;(confidence &lt; 80%)&#10;&#10;User can:&#10;✓ Confirm Finding&#10;✗ Reject (false positive)&#10;✎ Modify (change severity)&#10;↺ Reset (back to needs_review)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#FFD54F;fontSize=9;align=left;spacingLeft=8;fontColor=#F57F17;" parent="1" vertex="1">
                    <mxGeometry x="310" y="1275" width="200" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="hitl3" value="&lt;b&gt;POST .../review&lt;/b&gt;&#10;{action, note,&#10; modified_severity}&#10;&#10;action: approve | reject&#10;| modify | reset" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B2DFDB;strokeColor=#26A69A;fontSize=9;fontColor=#00695C;" parent="1" vertex="1">
                    <mxGeometry x="540" y="1280" width="160" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="hitl4" value="&lt;b&gt;Updated HITL status&lt;/b&gt;&#10;&#10;auto_approved (≥80%)&#10;needs_review (&lt;80%)&#10;user_approved&#10;user_rejected → resolved&#10;user_modified&#10;reset → needs_review" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#81C784;fontSize=9;align=left;spacingLeft=8;fontColor=#2E7D32;" parent="1" vertex="1">
                    <mxGeometry x="730" y="1270" width="180" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="hitl5" value="&lt;b&gt;HITL Summary Bar&lt;/b&gt;&#10;{needsReview, autoApproved,&#10; userApproved, userRejected}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#9575CD;fontSize=9;fontColor=#4527A0;" parent="1" vertex="1">
                    <mxGeometry x="940" y="1295" width="190" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="ca1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#78909C;" parent="1" source="trigger" target="loaddata" edge="1">
