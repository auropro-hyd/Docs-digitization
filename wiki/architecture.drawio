                <mxCell id="sec4-label" value="&lt;b&gt;STEP 3: Inside One LLM Call (zoom into a single cell)&lt;/b&gt;" style="text;html=1;fontSize=13;fontColor=#BF360C;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1170" y="190" width="470" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="zoom-prompt" value="&lt;b&gt;Prompt built by _build_batch_prompt():&lt;/b&gt;&#10;&#10;&quot;Evaluate ONLY the following 7 rules&#10;against this page content.&#10;For each rule return:&#10;  rule_id, status, &lt;b&gt;confidence&lt;/b&gt;,&#10;  severity, evidence,&#10;  description, recommendation.&#10;&#10;Also extract cross_references&#10;(SOP refs, batch IDs, equipment IDs)&#10;&#10;SECTION: Batch Manufacturing Record (pg 3-8)&#10;&#10;RULES TO EVALUATE:&#10;- [ALC-ATT1] All entries must have author ID&#10;- [ALC-ATT2] Signatures must be traceable&#10;- [ALC-ATT3] Electronic entries have audit trail&#10;  ... (4 more)&#10;&#10;PAGE CONTENT (page 3):&#10;\`\`\`&#10;{first 6000 chars of page markdown}&#10;\`\`\`&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#90A4AE;fontSize=8;align=left;spacingLeft=8;fontColor=#37474F;" parent="1" vertex="1">
                    <mxGeometry x="1175" y="220" width="270" height="310" as="geometry"/>
                </mxCell>
                <mxCell id="zoom-llm" value="&lt;b&gt;GPT-4.1-mini&lt;/b&gt;&#10;generate_structured()&#10;↓&#10;response_format =&#10;RuleBatchResult" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF8A65;fontSize=9;align=center;fontColor=#BF360C;" parent="1" vertex="1">
                    <mxGeometry x="1175" y="545" width="270" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="zoom-result" value="&lt;b&gt;RuleBatchResult { evaluations: [&lt;/b&gt;&#10;&#10;  { rule_id: &quot;ALC-ATT1&quot;,&#10;    status: &quot;compliant&quot;,&#10;    confidence: 0.95,&#10;    severity: null,&#10;    evidence: &quot;&quot; },&#10;&#10;  { rule_id: &quot;ALC-ATT2&quot;,&#10;    status: &quot;non_compliant&quot;,&#10;    confidence: 0.72,&#10;    severity: &quot;major&quot;,&#10;    evidence: &quot;Signature on line 14...&quot;,&#10;    description: &quot;Missing operator ID...&quot;,&#10;    recommendation: &quot;Add operator...&quot; },&#10;&#10;  { rule_id: &quot;ALC-ATT3&quot;,&#10;    status: &quot;not_applicable&quot;,&#10;    confidence: 0.98 },&#10;  ...&#10;&lt;b&gt;],  cross_references: [&lt;/b&gt;&#10;  { ref_type: &quot;sop_reference&quot;,&#10;    identifier: &quot;SOP-PRD-042&quot;,&#10;    context: &quot;Referenced in step 3.2&quot; }&#10;&lt;b&gt;]}&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#90A4AE;fontSize=8;align=left;spacingLeft=8;fontColor=#37474F;" parent="1" vertex="1">
                    <mxGeometry x="1475" y="220" width="250" height="360" as="geometry"/>
                </mxCell>
                <mxCell id="fo-e4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#78909C;" parent="1" source="zoom-prompt" target="zoom-llm" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="fo-e5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#78909C;" parent="1" source="zoom-llm" target="zoom-result" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="1310" y="585"/>
                            <mxPoint x="1460" y="585"/>
                            <mxPoint x="1460" y="400"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="sec5-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBE9E7;strokeColor=#FF8A65;dashed=1;dashPattern=5 5;opacity=30;" parent="1" vertex="1">
                    <mxGeometry x="30" y="610" width="420" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="sec5-label" value="&lt;b&gt;STEP 4: Progress Callback (per completed task)&lt;/b&gt;" style="text;html=1;fontSize=11;fontColor=#BF360C;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="615" width="400" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="cb-code" value="&lt;b&gt;progress_callback(completed, total, batch, result)&lt;/b&gt;&#10;&#10;1. llm_call_count += 1&#10;2. For each evaluation in result:&#10;   • Merge status:  non_compliant &gt; uncertain &gt; compliant&#10;   • Merge confidence:  min(prev, new)&#10;   • Update rule_statuses[rule_id]&#10;3. Collect cross_references → dependency_tags&#10;4. Build rule_updates list&#10;5. Broadcast WS message:" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBE9E7;strokeColor=#FF8A65;fontSize=8;align=left;spacingLeft=8;fontColor=#BF360C;" parent="1" vertex="1">
                    <mxGeometry x="40" y="642" width="260" height="145" as="geometry"/>
                </mxCell>
                <mxCell id="ws-msg-detail" value="&lt;b&gt;WS: compliance_progress&lt;/b&gt;&#10;{&#10;  phase: &quot;evaluation&quot;,&#10;  agent: &quot;alcoa&quot;,&#10;  batches_complete: 47,&#10;  batches_total: 216,&#10;  percent: 21,&#10;  rule_updates: [&#10;    {rule_id: &quot;ALC-ATT1&quot;,&#10;     status: &quot;compliant&quot;,&#10;     confidence: 0.95},&#10;    {rule_id: &quot;ALC-ATT2&quot;,&#10;     status: &quot;non_compliant&quot;,&#10;     confidence: 0.72}&#10;  ]&#10;}" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#FBE9E7;strokeColor=#FF8A65;fontSize=8;align=left;spacingLeft=6;fontColor=#BF360C;" parent="1" vertex="1">
                    <mxGeometry x="310" y="642" width="140" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="sec6-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#81C784;dashed=1;dashPattern=5 5;opacity=30;" parent="1" vertex="1">
                    <mxGeometry x="480" y="610" width="900" height="250" as="geometry"/>
                </mxCell>
                <mxCell id="sec6-label" value="&lt;b&gt;STEP 5: assemble_agent_report() — Collect, Deduplicate, Score&lt;/b&gt;" style="text;html=1;fontSize=13;fontColor=#2E7D32;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="490" y="615" width="560" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="raw-results" value="&lt;b&gt;216 raw results&lt;/b&gt;&#10;(batch_id, page_num, RuleBatchResult)&#10;&#10;Same rule may appear on&#10;multiple pages with different&#10;status / confidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF8A65;fontSize=9;align=left;spacingLeft=8;fontColor=#BF360C;" parent="1" vertex="1">
                    <mxGeometry x="500" y="650" width="200" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="dedup" value="&lt;b&gt;_deduplicate_findings()&lt;/b&gt;&#10;&#10;For each unique rule_id:&#10;  • Merge page_numbers&#10;  • Take worst severity&#10;  • Take minimum confidence&#10;  • Keep first evidence&#10;  • Recompute hitl_status&#10;&#10;Sort by severity (desc)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#81C784;fontSize=9;align=left;spacingLeft=8;fontColor=#2E7D32;" parent="1" vertex="1">
                    <mxGeometry x="740" y="645" width="195" height="145" as="geometry"/>
                </mxCell>
                <mxCell id="hitl-thresh" value="&lt;b&gt;HITL Threshold&lt;/b&gt;&#10;&#10;confidence ≥ 0.80&#10;  → auto_approved ✓&#10;&#10;confidence &lt; 0.80&#10;  → needs_review ⚠" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#FFD54F;fontSize=9;align=left;spacingLeft=8;fontColor=#F57F17;" parent="1" vertex="1">
                    <mxGeometry x="975" y="645" width="155" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="agent-report" value="&lt;b&gt;AgentReport&lt;/b&gt;&#10;&#10;agent: &quot;alcoa&quot;&#10;score: 75.0 / 100&#10;total_rules: 82&#10;total_findings: 12&#10;severity_counts: {critical: 1, major: 5, ...}&#10;category_scores: [CategoryScore × 9]&#10;findings: [ComplianceFinding × 12]&#10;pages_reviewed: [1..12]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#66BB6A;fontSize=9;align=left;spacingLeft=8;fontColor=#2E7D32;" parent="1" vertex="1">
                    <mxGeometry x="1170" y="640" width="195" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="fo-e6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#78909C;" parent="1" source="raw-results" target="dedup" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="fo-e7" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#78909C;" parent="1" source="dedup" target="hitl-thresh" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="fo-e8" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#78909C;" parent="1" source="hitl-thresh" target="agent-report" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="scoring" value="&lt;b&gt;Agent Score Calculation&lt;/b&gt;&#10;&#10;score = 100 − Σ( SEVERITY_WEIGHTS[finding.severity] )&#10;&#10;SEVERITY_WEIGHTS:&#10;  critical = 10,  major = 5,  minor = 2,  observation = 1&#10;&#10;Example: 1×critical + 5×major + 3×minor + 3×observation&#10;         = 10 + 25 + 6 + 3 = 44  →  score = 56/100" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#90A4AE;fontSize=9;align=left;spacingLeft=10;fontColor=#37474F;" parent="1" vertex="1">
                    <mxGeometry x="480" y="870" width="470" height="115" as="geometry"/>
