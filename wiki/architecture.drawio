    <diagram id="fanout-detail" name="Batch x Page Fan-Out (Deep Dive)">
        <mxGraphModel dx="1250" dy="821" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1400" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="fo-title" value="&lt;b&gt;Batch × Page Fan-Out — Deep Dive&lt;/b&gt;&#10;&lt;i&gt;How a single compliance agent evaluates all its rules against all document pages&lt;/i&gt;" style="text;html=1;fontSize=18;fontColor=#1A237E;align=center;" parent="1" vertex="1">
                    <mxGeometry x="300" y="10" width="1200" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="sec1-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#9575CD;dashed=1;dashPattern=5 5;opacity=30;" parent="1" vertex="1">
                    <mxGeometry x="30" y="70" width="420" height="520" as="geometry"/>
                </mxCell>
                <mxCell id="sec1-label" value="&lt;b&gt;STEP 1: Rule Registry → Batches&lt;/b&gt;" style="text;html=1;fontSize=13;fontColor=#4527A0;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="75" width="400" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="rulefile" value="&lt;b&gt;alcoa_rules.md&lt;/b&gt;&#10;&#10;Category: Attributable&#10;  1. All entries must have author ID&#10;  2. Signatures must be traceable&#10;  3. Electronic entries have audit trail&#10;  ...&#10;  10. Observer signatures present&#10;&#10;Category: Legible&#10;  1. Handwriting is readable&#10;  2. No overwritten entries&#10;  ...&#10;  8. Font size adequate&#10;&#10;Category: Contemporaneous&#10;  1. Entries dated at time of activity&#10;  ...&#10;  9. No backdated entries" style="shape=note;whiteSpace=wrap;html=1;size=18;fillColor=#EDE7F6;strokeColor=#9575CD;fontSize=8;align=left;spacingLeft=8;fontColor=#4527A0;" parent="1" vertex="1">
