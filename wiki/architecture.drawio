                <mxCell id="ext-ollama" value="&lt;b&gt;Local LLM (optional)&lt;/b&gt;&#10;runtime model&#10;on-prem inference" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#AB47BC;fontSize=9;fontColor=#6A1B9A;" parent="ext-group" vertex="1">
                    <mxGeometry x="465" y="30" width="150" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="ext-pg" value="&lt;b&gt;PostgreSQL&lt;/b&gt;&#10;asyncpg&#10;LISTEN/NOTIFY" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#4DB6AC;fontSize=9;fontColor=#00695C;" parent="ext-group" vertex="1">
                    <mxGeometry x="630" y="30" width="150" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="ext-fs" value="&lt;b&gt;Filesystem / Azure Blob&lt;/b&gt;&#10;data/documents/{doc_id}/&#10;├── *.pdf&#10;├── result.json&#10;├── document.json&#10;├── compliance_result.json&#10;├── segmentation.json&#10;├── dependency_tags.json&#10;├── auto_discovered_rules.json&#10;└── *.lock (processing, compliance)" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#E8F5E9;strokeColor=#66BB6A;fontSize=8;align=left;fontColor=#2E7D32;" parent="ext-group" vertex="1">
