# Azure AI Inference Configuration
# Copy this file to .env and fill in your actual values

# Your Azure Foundry endpoint URL
# Format: https://<your-deployment-name>.<your-azure-region>.models.ai.azure.com
AZURE_AI_ENDPOINT=https://your-endpoint.eastus.models.ai.azure.com

# Your API key for authentication
AZURE_AI_API_KEY=your-api-key-here

# Optional: Model name - ONLY needed for GitHub Models or multi-model endpoints
# For serverless API endpoints, the model is already specified in the endpoint URL
# Leave commented out or empty for serverless endpoints
# AZURE_AI_MODEL_NAME=llama-3.2-11B-vision-instruct
